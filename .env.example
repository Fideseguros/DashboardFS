# App
APP_SECRET_KEY=change-me-to-a-random-string
DATABASE_PATH=data/fide.db

# PII encryption (MUST be set in production, ~64 random chars)
FIELD_ENCRYPTION_KEY=change-me-to-a-long-random-string

# Session
SESSION_EXPIRY_HOURS=4

# Login rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Cookie security (set to 0 only for local dev over HTTP)
COOKIE_SECURE=1
